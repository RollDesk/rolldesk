# Copy this file to .env and adjust the values.
# On the target server, keep .env next to docker-compose.yml.

# ---- Access control ----
# Comma- or space-separated list of allowed IPs / CIDR subnets (IPv4/IPv6).
# Example: 203.0.113.4, 198.51.100.0/24, 10.8.0.0/24
# Empty = access from any IP (NOT recommended in production).
ALLOWED_IPS=

# ---- HTTP port exposed by the frontend (nginx) ----
HTTP_PORT=8080

# ---- Public application URL ----
# Where RollDesk is reachable for end users, e.g. https://rolldesk.example.com
# When set, outgoing notifications (webhooks / e-mail) include a link back to
# the app. Leave empty to omit links.
# REQUIRED for single sign-on (SSO): it is used to build the OIDC redirect URI
# (<APP_BASE_URL>/api/auth/sso/callback) that you register in the identity provider.
APP_BASE_URL=

# ---- PostgreSQL ----
POSTGRES_USER=rolldesk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rolldesk

# ---- Authentication ----
# Secret used to sign session tokens (JWT). REQUIRED in production — the backend
# refuses to start without it. Generate a strong value, e.g.:
#   openssl rand -hex 32
# In development it may be left empty (an ephemeral secret is generated, so
# sessions reset whenever the backend restarts).
JWT_SECRET=

# ---- Single sign-on (SSO) ----
# Per-domain OIDC providers (Azure/Entra ID, Google, generic) are configured at
# runtime by an admin in the app; only this encryption key lives in the env.
# It protects the stored IdP client secrets at rest (AES-256-GCM). If empty, it
# is derived from JWT_SECRET; set a dedicated random value in production, e.g.:
#   openssl rand -hex 32
# SSO also requires APP_BASE_URL (see above).
SSO_ENC_KEY=

# ---- Virus scanning (ClamAV, runs as a separate container) ----
# Uploaded attachments are streamed to clamd before being stored. The compose
# files default CLAMAV_HOST to the bundled "clamav" service; leave these unless
# you point at an external scanner. Set CLAMAV_HOST empty to disable scanning.
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# reject = block uploads when the scanner is unavailable (fail closed);
# allow  = accept unscanned uploads when the scanner is down (fail open).
CLAMAV_FAIL_MODE=reject

# ---- SMTP (optional, for email notifications) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RollDesk <no-reply@rolldesk.local>

# ---- Deployment from GitHub Container Registry (used by docker-compose.prod.yml) ----
# Set to your registry image prefix, e.g. ghcr.io/your-org/rolldesk
# The workflow appends "-backend" and "-frontend" to this prefix.
IMAGE_PREFIX=ghcr.io/your-org/rolldesk
# Image tag to run on the server (the deploy workflow sets this per release).
TAG=latest
